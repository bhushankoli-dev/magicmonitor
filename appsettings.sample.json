{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ImportantProcesses": [
    "jw_atm_host_v2.exe"
  ],
  "ImportantProcessPaths": {
    "jw_atm_host_v2.exe": "C:\\jw_atm_host_v2_MX"
  },
  "ProcessRestart": {
    "Mode": "ScheduledTask",
    "Tasks": {
      "jw_atm_host_v2.exe": "Restart_jw_atm_host_v2"
    }
  },
  "ProcessMonitoring": {
    "FlagReminderMinutes": 3
  },
  "ProcessRestartSchedule": {
    "Enabled": true,
    "Mode": "Fixed",
    "IntervalMinutes": 1,
    "Times": [ "12:35" ],
    "Include": [ "jw_atm_host_v2.exe" ],
    "Exclude": []
  },
  "Thresholds": {
    "CpuUsage": 80.0,
    "RamUsage": 90.0,
    "DiskSpaceThreshold": 2,
    "DiskSummaryThreshold": 10
  },
  "DiskCheckSchedule": {
    "Times": [],
    "Mode": "Interval",
    "IntervalMinutes": 60
  },
  "Schedules": {
    "CpuMonitoringIntervalSeconds": 40,
    "RamMonitoringIntervalSeconds": 50,
    "ImportantProcessMonitoringIntervalMinutes": 1,
    "SpikeHoldDurationSeconds": 10,
    "PostDropSilenceWindowMinutes": 10
  },
  "DiskResize": {
    "PercentIncrease": 20,
    "MinIncreaseGiB": 1
  },
  "RelayServer": {
    "Ip": "10.0.2.100",
    "Port": 5050
  },
  "Heartbeat": {
    "IntervalSeconds": 20,
    "TimeZone": "India Standard Time",
    "TimeFormat": "yyyy-MM-dd HH:mm:ss"
  },
  "DailyReportEmail": {
    "Enable": true,
    "RunAtLocalTime": "18:57",
    "Recipients": [ "abc@xyz.com" ],
    "Include": [ "CPU", "RAM" ],
    "Transport": "RelayBase64",
    "ZipAttachments": false,
    "SubjectTemplate": "Daily Excel Report: - {Bank} {InstanceName} {InstanceIp}",
    "BodyTemplate": "Dear Sir,\n\n{InstanceName} Performance Report: - {ReportDate}, 12:00am to 11:59pm.\nPFA."
  },
  "AwsEnvironment": {
    "AccountName": "abc pvt ltd"
  },
  "AutoUpdate": {
    "Enabled": true,
    "CheckIntervalMinutes": 60,
    "RelayUpdatePort": 9999,
    "InstallPath": "C:\\Deploy\\Monitor",
    "RestartDelaySeconds": 5
  }
}
